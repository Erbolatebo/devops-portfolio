---
import { profile } from "../data/profile";
---

<section class="hero">
  <div class="container">
    <div class="hero-content">
      <p class="hero-status">
        <span class="status-dot"></span>
        Открыт к предложениям
      </p>
      <h1 class="hero-name">{profile.name}</h1>
      <p class="hero-title">
        {profile.title}
        <span class="hero-level">{profile.targetRole}</span>
      </p>
      <p class="hero-tagline">{profile.tagline}</p>
      <div class="hero-meta">
        <span class="meta-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
          {profile.location}
        </span>
        <span class="meta-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect>
            <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
          </svg>
          Полная занятость · Гибрид
        </span>
      </div>
      <div class="hero-actions">
        <a href="#contact" class="btn btn-primary">Связаться</a>
        <a href="#experience" class="btn btn-outline">Смотреть опыт</a>
      </div>
    </div>

    <div class="hero-stats">
      {
        profile.highlights.map((item) => (
          <div class="stat-card">
            <span class="stat-value">{item.value}</span>
            <span class="stat-label">{item.label}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .hero {
    padding: calc(var(--header-height) + 80px) 0 80px;
  }

  .hero .container {
    display: grid;
    gap: 48px;
  }

  .hero-status {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 20px;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 8px var(--accent-glow);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .hero-name {
    font-size: clamp(2.5rem, 7vw, 4rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 8px;
  }

  .hero-title {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-weight: 500;
    color: var(--accent);
    margin-bottom: 16px;
  }

  .hero-level {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-muted);
    background: var(--bg-card);
    border: 1px solid var(--border);
    padding: 4px 10px;
    border-radius: 999px;
  }

  .hero-tagline {
    font-size: 1.1rem;
    color: var(--text-muted);
    max-width: 560px;
    margin-bottom: 24px;
  }

  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    margin-bottom: 32px;
  }

  .meta-item {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .meta-item svg {
    color: var(--accent);
    flex-shrink: 0;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 16px;
  }

  .stat-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px;
    transition: border-color 0.2s;
  }

  .stat-card:hover {
    border-color: var(--border-hover);
  }

  .stat-value {
    display: block;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--accent);
    font-family: var(--font-mono);
    margin-bottom: 4px;
  }

  .stat-label {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  @media (min-width: 900px) {
    .hero .container {
      grid-template-columns: 1fr 1fr;
      align-items: center;
    }
  }
</style>
